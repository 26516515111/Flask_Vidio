# ===========================================
# 语音转换助手 - Environment Variables
# ===========================================
#
# Vercel 部署说明:
# 1. 在 Vercel Dashboard → Settings → Environment Variables 中设置以下变量
# 2. Vercel Hobby 计划函数超时 300s, Pro 计划 800s
# 3. TTS/LLM 调用最大耗时约 50s, 需确保 Vercel 函数超时大于此值
# 4. 修改环境变量后需重新部署才能生效
#
# 本地开发:
# 复制此文件为 .env 并填入真实值
# ===========================================

# 小米 Token Plan API 配置 (必需)
XIAOMI_TOKENPLAN_API_KEY=your_api_key_here
XIAOMI_TOKENPLAN_API_BASE=https://token-plan-cn.xiaomimimo.com/v1

# API 本地开发端口 (可选)
# API_PORT=5001
